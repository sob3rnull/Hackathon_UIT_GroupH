# Copy to .env.local and fill in. The app runs WITHOUT any of these — it falls
# back to an in-memory hospital store and keyword triage — so it stays demoable
# even with no database and no network.

# Supabase → Project Settings → Data API / API Keys.
# Both are public values; the anon key is designed to ship in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL. Bypasses RLS. The app works without it — the store falls back to
# the anon key and lets table policies govern access. Never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Enables real AI triage. Without it, /api/triage uses the keyword fallback
# and the UI says so. Server-only — never prefix with NEXT_PUBLIC_, or you
# ship your key to every visitor.
ANTHROPIC_API_KEY=

# Google Routes API — SERVER-SIDE ONLY, never NEXT_PUBLIC_. Used by the local
# backend; the n8n backend carries its own copy inside the workflow. Blank =
# the engine falls back to haversine estimates.
GOOGLE_ROUTES_API_KEY=

# Maps JavaScript API — a DIFFERENT key from the Routes one. It ships in the
# browser bundle by design; protect it with HTTP-referrer + API restrictions
# in Cloud Console, not by hiding it. Blank = offline SVG map.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Point the frontend at the n8n backend. Blank = local Next.js route handlers.
NEXT_PUBLIC_MEDIROUTE_API=
