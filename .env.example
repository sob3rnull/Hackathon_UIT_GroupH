# Copy to .env.local and fill in. The app runs WITHOUT any of these — it falls
# back to an in-memory hospital store and keyword triage — so it stays demoable
# even with no database and no network.

# Supabase → Project Settings → Data API / API Keys.
# Both are public values; the anon key is designed to ship in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL. Bypasses RLS. The app works without it — the store falls back to
# the anon key and lets table policies govern access. Never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Enables real AI triage. Without it, /api/triage uses the keyword fallback
# and the UI says so. Server-only — never prefix with NEXT_PUBLIC_, or you
# ship your key to every visitor.
ANTHROPIC_API_KEY=

# Server-side dictation (Whisper) for /api/transcribe. Set ONE of these; OpenAI
# wins if both are present. Groq has a free tier and strong Burmese
# (whisper-large-v3). Blank = the mic falls back to the browser's own speech
# service (Chrome/Edge only, fails on filtered networks). Server-only keys.
OPENAI_API_KEY=
GROQ_API_KEY=

# Google Routes API — SERVER-SIDE ONLY, never NEXT_PUBLIC_. Used by the local
# backend; the n8n backend carries its own copy inside the workflow. Blank =
# the engine falls back to haversine estimates.
GOOGLE_ROUTES_API_KEY=

# Google Geocoding API — SERVER-SIDE ONLY. Fallback for /api/locate when a place
# from the dispatcher note isn't in the hardcoded gazetteer (landmarks.ts). Needs
# the Geocoding API enabled on the key. Blank = gazetteer-only (curated Yangon
# landmarks). If left blank the code also tries GOOGLE_ROUTES_API_KEY, which only
# works if that key has the Geocoding API enabled too.
GOOGLE_GEOCODING_API_KEY=

# Maps JavaScript API — a DIFFERENT key from the Routes one. It ships in the
# browser bundle by design; protect it with HTTP-referrer + API restrictions
# in Cloud Console, not by hiding it. Blank = offline SVG map.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional. Verifies GET /api/cron/gps-heartbeat is really Vercel Cron (see
# vercel.json) — Vercel sends it as a Bearer token automatically when set.
# Blank = the endpoint accepts any caller (still only refreshes GPS timestamps,
# nothing destructive, but set this in production).
CRON_SECRET=
