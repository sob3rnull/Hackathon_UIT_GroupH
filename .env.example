# Copy to .env.local and fill in. The app runs WITHOUT any of these —
# it falls back to an in-memory store — so it stays demoable even if the
# database is unreachable.

# Supabase → Project Settings → Data API / API Keys.
# Both are public values; the anon key is designed to ship in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL. Bypasses RLS. The app works fine without it — the store falls
# back to the anon key and lets table policies govern access. Only add this
# if you need server-side access that ignores policies.
# Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Table the store reads/writes. Rename alongside your entity.
SUPABASE_TABLE=items
